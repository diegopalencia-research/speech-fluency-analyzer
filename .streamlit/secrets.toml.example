# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml for local use.
# On Streamlit Cloud: paste keys in App Settings → Secrets.
# DO NOT commit secrets.toml to GitHub (it is in .gitignore).
#
# ALL KEYS ARE OPTIONAL — the app runs fully free without any of them.
# ─────────────────────────────────────────────────────────────────────────────

# Optional: enables OpenAI Whisper API (faster transcription, ~5s vs ~30s local)
OPENAI_API_KEY = "sk-your-openai-key"

# Optional: enables Groq AI coaching (free tier — no credit card at console.groq.com)
GROQ_API_KEY = "gsk_your-groq-key"
